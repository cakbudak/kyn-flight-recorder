{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyn.ist/schema/kyn-flight-trace-v1.schema.json",
  "title": "Kyn Flight Trace v1",
  "description": "Structural envelope for the standalone synthetic flight recorder. Cross-field invariants are enforced by app/core.mjs.",
  "type": "object",
  "required": [
    "schema_version",
    "fixture",
    "run",
    "nodes",
    "edges",
    "events",
    "intervention",
    "redaction"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1.0" },
    "fixture": { "$ref": "#/$defs/fixture" },
    "run": { "$ref": "#/$defs/run" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/event" }
    },
    "intervention": { "$ref": "#/$defs/intervention" },
    "redaction": { "$ref": "#/$defs/redaction" }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "timestampOrNull": {
      "oneOf": [
        { "type": "string", "format": "date-time" },
        { "type": "null" }
      ]
    },
    "diagnosis": {
      "type": "object",
      "required": ["eyebrow", "title", "summary", "cause_node_id", "confidence", "next_action"],
      "additionalProperties": false,
      "properties": {
        "eyebrow": { "$ref": "#/$defs/nonEmptyString" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "summary": { "$ref": "#/$defs/nonEmptyString" },
        "cause_node_id": { "$ref": "#/$defs/nonEmptyString" },
        "confidence": { "$ref": "#/$defs/nonEmptyString" },
        "next_action": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "fixture": {
      "type": "object",
      "required": ["id", "title", "classification", "created_at", "description"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "classification": { "const": "synthetic_demo" },
        "created_at": { "type": "string", "format": "date-time" },
        "description": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "run": {
      "type": "object",
      "required": [
        "id",
        "correlation_id",
        "status",
        "revision",
        "started_at",
        "updated_at",
        "duration_ms",
        "definition",
        "agent",
        "goal",
        "diagnosis",
        "impact"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "correlation_id": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "enum": ["blocked", "completed"] },
        "revision": { "type": "integer", "minimum": 0 },
        "started_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "definition": {
          "type": "object",
          "required": ["slug", "version", "fingerprint"],
          "additionalProperties": false,
          "properties": {
            "slug": { "$ref": "#/$defs/nonEmptyString" },
            "version": { "$ref": "#/$defs/nonEmptyString" },
            "fingerprint": { "$ref": "#/$defs/nonEmptyString" }
          }
        },
        "agent": {
          "type": "object",
          "required": ["name", "runtime", "model", "permission_mode"],
          "additionalProperties": false,
          "properties": {
            "name": { "$ref": "#/$defs/nonEmptyString" },
            "runtime": { "$ref": "#/$defs/nonEmptyString" },
            "model": { "$ref": "#/$defs/nonEmptyString" },
            "permission_mode": { "$ref": "#/$defs/nonEmptyString" }
          }
        },
        "goal": { "$ref": "#/$defs/nonEmptyString" },
        "diagnosis": { "$ref": "#/$defs/diagnosis" },
        "impact": {
          "type": "object",
          "required": ["scope", "risk", "external_effect"],
          "additionalProperties": false,
          "properties": {
            "scope": { "$ref": "#/$defs/nonEmptyString" },
            "risk": { "$ref": "#/$defs/nonEmptyString" },
            "external_effect": { "const": false }
          }
        }
      }
    },
    "node": {
      "type": "object",
      "required": ["id", "order", "lane", "kind", "title", "subtitle", "source", "status", "observed_at", "evidence", "fields"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "order": { "type": "integer", "minimum": 1 },
        "lane": { "enum": ["main", "guardrail"] },
        "kind": { "$ref": "#/$defs/nonEmptyString" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "subtitle": { "$ref": "#/$defs/nonEmptyString" },
        "source": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "enum": ["blocked", "completed", "healthy", "pending", "waiting"] },
        "observed_at": { "$ref": "#/$defs/timestampOrNull" },
        "evidence": { "$ref": "#/$defs/nonEmptyString" },
        "fields": { "type": "object" }
      }
    },
    "edge": {
      "type": "object",
      "required": ["id", "from", "to", "relation", "status"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "from": { "$ref": "#/$defs/nonEmptyString" },
        "to": { "$ref": "#/$defs/nonEmptyString" },
        "relation": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "enum": ["blocked", "healthy", "pending", "traversed"] }
      }
    },
    "event": {
      "type": "object",
      "required": ["id", "sequence", "occurred_at", "source", "type", "status", "summary", "correlation_id", "detail"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "sequence": { "type": "integer", "minimum": 1 },
        "occurred_at": { "type": "string", "format": "date-time" },
        "source": { "$ref": "#/$defs/nonEmptyString" },
        "type": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "$ref": "#/$defs/nonEmptyString" },
        "summary": { "$ref": "#/$defs/nonEmptyString" },
        "correlation_id": { "$ref": "#/$defs/nonEmptyString" },
        "detail": { "type": "object" }
      }
    },
    "previewItem": {
      "type": "object",
      "required": ["label", "value"],
      "additionalProperties": false,
      "properties": {
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "value": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "nodeUpdate": {
      "type": "object",
      "required": ["status", "subtitle", "observed_at"],
      "additionalProperties": false,
      "properties": {
        "status": { "const": "completed" },
        "subtitle": { "$ref": "#/$defs/nonEmptyString" },
        "observed_at": { "type": "string", "format": "date-time" }
      }
    },
    "resolution": {
      "type": "object",
      "required": ["new_revision", "completed_at", "diagnosis", "node_updates", "edge_updates", "events"],
      "additionalProperties": false,
      "properties": {
        "new_revision": { "type": "integer", "minimum": 1 },
        "completed_at": { "type": "string", "format": "date-time" },
        "diagnosis": { "$ref": "#/$defs/diagnosis" },
        "node_updates": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/nodeUpdate" }
        },
        "edge_updates": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "const": "traversed" }
        },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/event" }
        }
      }
    },
    "intervention": {
      "type": "object",
      "required": [
        "command_id",
        "idempotency_key",
        "type",
        "label",
        "description",
        "expected_revision",
        "allowed_from",
        "actor",
        "scope",
        "preview",
        "resolution"
      ],
      "additionalProperties": false,
      "properties": {
        "command_id": { "$ref": "#/$defs/nonEmptyString" },
        "idempotency_key": { "$ref": "#/$defs/nonEmptyString" },
        "type": { "const": "approve_tool_call" },
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "description": { "$ref": "#/$defs/nonEmptyString" },
        "expected_revision": { "type": "integer", "minimum": 0 },
        "allowed_from": { "const": "blocked" },
        "actor": { "$ref": "#/$defs/nonEmptyString" },
        "scope": { "$ref": "#/$defs/nonEmptyString" },
        "preview": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/previewItem" }
        },
        "resolution": { "$ref": "#/$defs/resolution" }
      }
    },
    "redaction": {
      "type": "object",
      "required": ["keys", "replacement"],
      "additionalProperties": false,
      "properties": {
        "keys": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "replacement": { "$ref": "#/$defs/nonEmptyString" }
      }
    }
  }
}
